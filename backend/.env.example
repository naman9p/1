# Application Settings
APP_NAME="AI Candidate Recommendation Engine"
APP_ENV="development"
DEBUG=true
LOG_LEVEL="INFO"

# Server Settings
HOST="0.0.0.0"
PORT=8000

# AI Model Settings
EMBEDDING_MODEL="BAAI/bge-large-en-v1.5"
FALLBACK_EMBEDDING_MODEL="all-MiniLM-L6-v2"
CROSS_ENCODER_MODEL="cross-encoder/ms-marco-MiniLM-L-6-v2"

# Vector Database
CHROMA_DB_PATH="./data/chroma_db"
CHROMA_COLLECTION="candidates"

# Scoring Weights (must sum to 1.0)
WEIGHT_SEMANTIC=0.40
WEIGHT_SKILL=0.20
WEIGHT_EXPERIENCE=0.10
WEIGHT_BEHAVIOR=0.10
WEIGHT_INDUSTRY=0.10
WEIGHT_EDUCATION=0.05
WEIGHT_BONUS=0.05

# Retrieval Settings
RETRIEVAL_TOP_K=300
RERANK_TOP_K=100
FINAL_OUTPUT_K=100

# Data Paths
DATA_DIR="./data"
CANDIDATES_FILE="./data/candidates.jsonl"
JOB_DESCRIPTION_FILE="./data/job_description.txt"
OUTPUT_FILE="./output/recommendations.csv"
